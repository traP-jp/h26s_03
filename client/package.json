{
  "name": "client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "openapi-typescript ../openapi/openapi.yaml -o src/gen/api-types.ts && oxfmt src/gen/api-types.ts",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "dev": "vp dev",
    "build": "vue-tsc --noEmit && vp build",
    "preview": "vp preview"
  },
  "dependencies": {
    "openapi-fetch": "^0.15.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "openapi-typescript": "latest",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "~6.0.2",
    "vite": "^7.1.3",
    "vite-plus": "latest",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.33.0"
}
